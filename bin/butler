#!/usr/bin/env python3
import os
import sys
import time

project_root = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
sys.path.insert(0, project_root)

from butler.butler import ButlerOrchestrator

def main():
    args = sys.argv[1:]
    force_flag = "-f" in args
    filtered_args = [a for a in args if a != "-f"]
    
    conn_spec = None
    if filtered_args:
        conn_spec = filtered_args[0]
        
    orchestrator = ButlerOrchestrator(conn_spec, force_flag)
    orchestrator.start()
    
    try:
        while True:
            time.sleep(1.0)
    except KeyboardInterrupt:
        sys.stderr.write("Butler Orchestrator interrupted. Exiting...\n")
        sys.stderr.flush()
    finally:
        orchestrator.stop()

if __name__ == "__main__":
    main()
