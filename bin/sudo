#!/bin/bash
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# 1. Safely correct paths in generated mosquitto config files to current root dir
CONF_DIR="$ROOT_DIR/impl/udmi/var/mosquitto"
if [[ -d "$CONF_DIR" ]]; then
    # Rewrite main conf file if exists
    if [[ -f "$CONF_DIR/mosquitto.conf" ]]; then
        sed -i "s%/home/peringknife/vibrant/impl_A%$ROOT_DIR%g" "$CONF_DIR/mosquitto.conf"
    fi
    # Rewrite udmi.conf if exists
    if [[ -f "$CONF_DIR/conf.d/udmi.conf" ]]; then
        sed -i "s%/home/peringknife/vibrant/impl_A%$ROOT_DIR%g" "$CONF_DIR/conf.d/udmi.conf"
    fi
fi

# 2. Rewrite any arguments passed to sudo that refer to the old impl_A path
ARGS=()
for arg in "$@"; do
    ARGS+=("${arg//\/home\/peringknife\/vibrant\/impl_A/$ROOT_DIR}")
done

exec "${ARGS[@]}"
