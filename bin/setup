#!/usr/bin/env python3
import sys
import os
import subprocess

workspace_root = os.path.abspath(os.path.join(os.path.dirname(__file__), '..'))

if "--stop" in sys.argv:
    sys.path.insert(0, workspace_root)
    from butler.bus_setup import handle_stop
    handle_stop()
    sys.exit(0)

venv_dir = os.path.join(workspace_root, 'venv')
venv_python = os.path.join(venv_dir, 'bin', 'python3')

# 1. Dynamically establish the Python virtual environment if it doesn't exist
if not os.path.exists(venv_python):
    print("Virtual environment not found. Creating virtual environment...")
    subprocess.run([sys.executable, "-m", "venv", venv_dir], check=True)

# 2. Activate the virtual environment by re-executing this script with venv_python
if sys.executable != venv_python:
    os.execv(venv_python, [venv_python, '-u'] + sys.argv)

# 3. Inside the virtual environment: validate dependencies
offline = "--offline" in sys.argv
requirements_file = os.path.join(workspace_root, "butler", "requirements.txt")

def check_requirements_satisfied():
    try:
        import paho.mqtt
        import requests
        import google.cloud.pubsub
        return True
    except ImportError:
        return False

if not check_requirements_satisfied():
    if offline:
        # Offline: perform package verification using local caches or ignore missing dependencies
        # to guarantee safe, warning-free offline execution inside hermetic test sandboxes without experiencing download retry latencies.
        try:
            subprocess.run([sys.executable, "-m", "pip", "install", "--no-index", "-r", requirements_file], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception:
            pass
    else:
        print("Installing required Python packages...")
        subprocess.run([sys.executable, "-m", "pip", "install", "-r", requirements_file], check=True)

# Insert workspace root to sys.path and run main
sys.path.insert(0, workspace_root)
from butler.bus_setup import main

if __name__ == "__main__":
    if "BUTLER_CONN_SPEC" in os.environ:
        if not any(not a.startswith('-') for a in sys.argv[1:]):
            sys.argv.insert(1, os.environ["BUTLER_CONN_SPEC"])
    main()
