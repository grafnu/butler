#!/bin/bash
#
#
# This script constructs the base directory structure (cloning sibling repos/branches as needed),
# runs the parallel Gemini update workflow on implementations A, B, C, D, and checks and pushes git updates.
#
# Usage: ./bin/run_updates

set -euo pipefail

# Force non-interactive fail-fast execution across all sub-shells/tools
export CLOUDSDK_CORE_DISABLE_PROMPTS=1
export DEBIAN_FRONTEND=noninteractive
export SUDO_ASKPASS=/bin/false

# Read and parse the authoritative UDMI version specification
UDMI_VERSION_FILE="udmi_version.txt"
if [ ! -f "${UDMI_VERSION_FILE}" ]; then
  echo "Error: Authoritative UDMI version specification file '${UDMI_VERSION_FILE}' not found. Aborting." >&2
  exit 1
fi

# Securely read space-separated fields without eval or variable injection risks
read -r UDMI_REPO_URL UDMI_TARGET < "${UDMI_VERSION_FILE}"

# Automatically default UDMI_LOCAL_PATH to /home/peringknife/udmi if it exists and is not set
if [ -z "${UDMI_LOCAL_PATH:-}" ] && [ -d "/home/peringknife/udmi/.git" ]; then
  export UDMI_LOCAL_PATH="/home/peringknife/udmi"
fi

# Verify both variables are populated
if [ -z "${UDMI_REPO_URL:-}" ] || [ -z "${UDMI_TARGET:-}" ]; then
  echo "Error: Incomplete UDMI version specification in '${UDMI_VERSION_FILE}'. Must contain exactly: <repo_url> <branch/commit/tag>" >&2
  exit 1
fi

# 1. Internal Configuration
IMPLEMENTATIONS=("A" "B" "C" "D")

if ! command -v gemini >/dev/null 2>&1; then
  echo "Error: gemini executable not found in PATH." >&2
  exit 1
fi
GEMINI_BIN="gemini"

GEMINI_OPTS=("--proxy=false" "--approval-mode" "yolo")

# The user can enable parallel execution using the optional '-p' or '--parallel' flag.
# Sibling workspace tasks will still write their standard log files for isolation,
# consistency, and error analysis.
USE_SANDBOX="${USE_SANDBOX:-false}"
USE_PARALLEL="${USE_PARALLEL:-false}"
for arg in "$@"; do
  if [ "$arg" = "-s" ] || [ "$arg" = "--sandbox" ]; then
    USE_SANDBOX="true"
  elif [ "$arg" = "-p" ] || [ "$arg" = "--parallel" ]; then
    USE_PARALLEL="true"
  fi
done

SANDBOX_OPTS=()
if [ "${USE_SANDBOX}" = "true" ]; then
  SANDBOX_OPTS=("-s")
fi

# Determine directories
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAIN_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
BASE_DIR="${MAIN_DIR}"

# Check for any uncommitted changes in the parent/main repository
if [ -d "${MAIN_DIR}/.git" ]; then
  UNCOMMITTED_CHANGES=$(git -C "${MAIN_DIR}" status --porcelain 2>/dev/null | grep -v -E "bin/run_updates|MERGER.md" || echo "")
  if [ -n "${UNCOMMITTED_CHANGES}" ]; then
    echo "Error: Uncommitted or unstaged changes detected in the parent repository. Aborting workflow to prevent stale synchronizations." >&2
    echo "${UNCOMMITTED_CHANGES}" >&2
    exit 1
  fi
fi

echo "=== System Configuration ==="
echo "Script directory:       ${SCRIPT_DIR}"
echo "Main workspace:         ${MAIN_DIR}"
echo "Base workspace directory: ${BASE_DIR}"
echo "Sub-implementations:   ${IMPLEMENTATIONS[*]}"
echo "Sandbox mode enabled:   ${USE_SANDBOX}"
echo "Parallel updates enabled: ${USE_PARALLEL}"
echo "============================="

# 2. Construct Base Directory Structure as Needed
cd "${MAIN_DIR}"

# Helper function to clone/setup a sibling directory with its branch
setup_sibling() {
  local dir_name="$1"
  local branch_name="$2"
  local target_dir="${BASE_DIR}/${dir_name}"

  # Ensure the branch exists and is fully up-to-date locally in MAIN_DIR
  # so that git clone . copies the freshest commit from origin
  cd "${MAIN_DIR}"
  local current_branch
  current_branch=$(git rev-parse --abbrev-ref HEAD)
  if [ "${branch_name}" != "${current_branch}" ]; then
    if git show-ref --verify --quiet "refs/remotes/origin/${branch_name}"; then
      git branch -f "${branch_name}" "origin/${branch_name}" >/dev/null 2>&1
    fi
  fi

  if [ ! -d "${target_dir}" ]; then
    echo "Directory ${dir_name} not found. Cloning into ${target_dir}..."
    mkdir -p "$(dirname "${target_dir}")"
    cd "${BASE_DIR}"
    git clone -q . "${dir_name}" >/dev/null 2>&1
  fi

  cd "${target_dir}"
  git fetch -q --all --prune >/dev/null 2>&1

  # Switch to the correct branch
  if git show-ref --verify --quiet "refs/heads/${branch_name}"; then
    git checkout -q "${branch_name}" >/dev/null 2>&1
  else
    git checkout -q -b "${branch_name}" "origin/${branch_name}" >/dev/null 2>&1
  fi

  # Ensure the working directory is updated to match origin
  git reset -q --hard "origin/${branch_name}" >/dev/null 2>&1

  # Automatically setup and pin the UDMI repository under impl/udmi inside this sibling workspace
  local sibling_udmi_dir="${target_dir}/impl/udmi"
  mkdir -p "$(dirname "${sibling_udmi_dir}")"

  # Determine the cloning source (support local development path override for developers)
  local udmi_source="${UDMI_REPO_URL}"
  if [ -n "${UDMI_LOCAL_PATH:-}" ]; then
    if [ -d "${UDMI_LOCAL_PATH}/.git" ]; then
      udmi_source="${UDMI_LOCAL_PATH}"
    else
      echo "Error: Explicit UDMI_LOCAL_PATH is set but does not point to a valid git repository (missing .git): '${UDMI_LOCAL_PATH}'" >&2
      exit 1
    fi
  fi

  if [ ! -d "${sibling_udmi_dir}/.git" ]; then
    git clone -q "${udmi_source}" "${sibling_udmi_dir}" >/dev/null 2>&1
  fi

  # Set the remote origin URL to the resolved cloning source (supporting local path override)
  git -C "${sibling_udmi_dir}" remote set-url origin "${udmi_source}" >/dev/null 2>&1
  git -C "${sibling_udmi_dir}" fetch -q --all --prune >/dev/null 2>&1

  # If target is a branch, reset to the remote tracking branch.
  # Otherwise, fall back to resetting to the local tag/commit reference.
  if git -C "${sibling_udmi_dir}" show-ref --verify --quiet "refs/remotes/origin/${UDMI_TARGET}"; then
    git -C "${sibling_udmi_dir}" checkout -q -f "${UDMI_TARGET}" >/dev/null 2>&1
    git -C "${sibling_udmi_dir}" reset -q --hard "origin/${UDMI_TARGET}" >/dev/null 2>&1
  else
    git -C "${sibling_udmi_dir}" checkout -q -f "${UDMI_TARGET}" >/dev/null 2>&1
    git -C "${sibling_udmi_dir}" reset -q --hard "${UDMI_TARGET}" >/dev/null 2>&1
  fi
}

# Setup implementations
for ID in "${IMPLEMENTATIONS[@]}"; do
  setup_sibling "impl/${ID}" "impl_${ID}"
done

echo "=== Checking UDMI Synchronization ==="
FIRST_UDMI_COMMIT=""
FIRST_UDMI_TIMESTAMP=""
SYNC_FAILED=0

for ID in "${IMPLEMENTATIONS[@]}"; do
  sibling_udmi_dir="${BASE_DIR}/impl/${ID}/impl/udmi"
  if [ ! -d "${sibling_udmi_dir}/.git" ]; then
    echo "Error: UDMI repository not found under ${sibling_udmi_dir}" >&2
    SYNC_FAILED=1
    continue
  fi

  commit=$(git -C "${sibling_udmi_dir}" rev-parse HEAD 2>/dev/null || echo "unknown")
  timestamp=$(TZ=UTC git -C "${sibling_udmi_dir}" log -1 --format="%cd" --date=iso-strict-local HEAD 2>/dev/null || echo "unknown")

  if [ -z "${FIRST_UDMI_COMMIT}" ]; then
    FIRST_UDMI_COMMIT="${commit}"
    FIRST_UDMI_TIMESTAMP="${timestamp}"
  elif [ "${commit}" != "${FIRST_UDMI_COMMIT}" ]; then
    echo "Error: Mismatched UDMI version found for impl_${ID} (${commit}) vs expected (${FIRST_UDMI_COMMIT})" >&2
    SYNC_FAILED=1
  fi
done

if [ "${SYNC_FAILED}" -ne 0 ]; then
  echo "Error: UDMI repositories are not synchronized to the identical version. Aborting workflow." >&2
  exit 1
fi

echo "All repositories synchronized to UDMI version: ${FIRST_UDMI_TIMESTAMP} (${FIRST_UDMI_COMMIT})"

echo "=== Base Directory Structure Verified/Constructed ==="

# Calculate branch-specific port and clean up lingering processes on it
cleanup_branch_ports() {
  local branch_name="$1"

  # Calculating the dynamic branch-mapped port via python3
  # guarantees that the entire 256-bit SHA256 hex string can be parsed as
  # an arbitrary-precision integer, perfectly matching the specification
  # and implementation formulas while completely avoiding bash 64-bit overflow.
  local port
  port=$(python3 -c "
import hashlib
h = hashlib.sha256(b'${branch_name}').hexdigest()
print(45000 + (int(h, 16) % 3000))
")

  local etcd_port=$((port + 1))
  local etcd_peer_port=$((port + 1001))

  for p in "${port}" "${etcd_port}" "${etcd_peer_port}"; do
    if lsof -i :"${p}" -t >/dev/null 2>&1; then
      local pids
      pids=$(lsof -i :"${p}" -t)
      echo "Port ${p} is occupied by lingering processes (PIDs: ${pids}) for ${branch_name}. Terminating..."
      for pid in ${pids}; do
        if kill -0 "${pid}" 2>/dev/null; then
          kill -15 "${pid}" 2>/dev/null # SIGTERM
          # Wait up to 3 seconds for graceful exit
          for _ in {1..30}; do
            sleep 0.1
            if ! kill -0 "${pid}" 2>/dev/null; then
              break
            fi
          done
          # Force kill if still running
          if kill -0 "${pid}" 2>/dev/null; then
            echo "Process ${pid} did not terminate gracefully. Force killing..."
            kill -9 "${pid}" 2>/dev/null # SIGKILL
          fi
        fi
      done
    fi
  done
}

echo "=== Cleaning Up Lingering Port Processes on Startup ==="
for ID in "${IMPLEMENTATIONS[@]}"; do
  cleanup_branch_ports "impl_${ID}"
done

# 3. Run Gemini Update Workflows (@UPDATE.md)
if [ "${USE_PARALLEL}" = "true" ]; then
  echo "=== Running Parallel Gemini Updates (@UPDATE.md) ==="
else
  echo "=== Running Serial Gemini Updates (@UPDATE.md) ==="
fi

declare -A PIDS
declare -A LOGS
declare -A INDIVIDUAL_TIMES
FAILED_IMPLS=()

IMPL_TIME="${IMPL_TIME:-20}"

for ID in "${IMPLEMENTATIONS[@]}"; do
  IMPL_DIR="${BASE_DIR}/impl/${ID}"
  LOG_FILE="${IMPL_DIR}.log"
  LOGS["$ID"]="${LOG_FILE}"

  if [ "${USE_PARALLEL}" = "true" ]; then
    echo "Launching gemini ${SANDBOX_OPTS[*]} -p @UPDATE.md for impl_${ID} in background (logging to ${LOG_FILE})..."
    (
      START_INDIVIDUAL=$SECONDS
      cd "${IMPL_DIR}"

      # Execute Gemini using the specified options and input @UPDATE.md with a ${IMPL_TIME}m timeout
      RET=0
      timeout ${IMPL_TIME}m "${GEMINI_BIN}" "${GEMINI_OPTS[@]}" "${SANDBOX_OPTS[@]}" -p @UPDATE.md < /dev/null > "${LOG_FILE}" 2>&1 || RET=$?
      if [ "${RET}" -ne 0 ]; then
        if [ "${RET}" -eq 124 ]; then
          echo "Error: Gemini @UPDATE.md run for impl_${ID} timed out after ${IMPL_TIME} minutes." >&2
          echo -e "PROCESSING ERROR: Gemini update run timed out after ${IMPL_TIME} minutes.\n" > "${IMPL_DIR}/spec_analysis.md"
        else
          echo "Error: Gemini @UPDATE.md run for impl_${ID} failed with exit code ${RET}." >&2
          echo -e "PROCESSING ERROR: Gemini update run failed with exit code ${RET}.\n" > "${IMPL_DIR}/spec_analysis.md"
        fi
      fi

      ELAPSED_INDIVIDUAL=$(( SECONDS - START_INDIVIDUAL ))
      echo "${ELAPSED_INDIVIDUAL}" > "${BASE_DIR}/impl/impl_${ID}.time"
      exit ${RET}
    ) &
    PIDS["$ID"]=$!
  else
    echo "Running gemini ${SANDBOX_OPTS[*]} -p @UPDATE.md for impl_${ID} sequentially (logging to ${LOG_FILE})..."
    START_INDIVIDUAL=$SECONDS
    cd "${IMPL_DIR}"

    # Execute Gemini using the specified options and input @UPDATE.md with a ${IMPL_TIME}m timeout
    RET=0
    timeout ${IMPL_TIME}m "${GEMINI_BIN}" "${GEMINI_OPTS[@]}" "${SANDBOX_OPTS[@]}" -p @UPDATE.md < /dev/null > "${LOG_FILE}" 2>&1 || RET=$?
    if [ "${RET}" -ne 0 ]; then
      if [ "${RET}" -eq 124 ]; then
        echo "Error: Gemini @UPDATE.md run for impl_${ID} timed out after ${IMPL_TIME} minutes." >&2
        echo -e "PROCESSING ERROR: Gemini update run timed out after ${IMPL_TIME} minutes.\n" > "${IMPL_DIR}/spec_analysis.md"
      else
        echo "Error: Gemini @UPDATE.md run for impl_${ID} failed with exit code ${RET}." >&2
        echo -e "PROCESSING ERROR: Gemini update run failed with exit code ${RET}.\n" > "${IMPL_DIR}/spec_analysis.md"
      fi
    fi

    ELAPSED_INDIVIDUAL=$(( SECONDS - START_INDIVIDUAL ))
    INDIVIDUAL_TIMES["$ID"]="${ELAPSED_INDIVIDUAL}"

    if [ "${RET}" -eq 0 ]; then
      echo "SUCCESS: impl_${ID} updated successfully in ${ELAPSED_INDIVIDUAL}s."
    else
      echo "FAILURE: impl_${ID} update failed in ${ELAPSED_INDIVIDUAL}s. Check log: ${LOG_FILE}"
      FAILED_IMPLS+=("${ID}")
    fi
  fi
done

# Wait for all processes to complete if running in parallel
if [ "${USE_PARALLEL}" = "true" ]; then
  echo "Waiting for parallel update processes to complete..."
  for ID in "${IMPLEMENTATIONS[@]}"; do
    PID=${PIDS["$ID"]}
    if wait "${PID}"; then
      ELAPSED_INDIVIDUAL=$(cat "${BASE_DIR}/impl/impl_${ID}.time" 2>/dev/null || echo "0")
      echo "SUCCESS: impl_${ID} updated successfully in ${ELAPSED_INDIVIDUAL}s."
      INDIVIDUAL_TIMES["$ID"]="${ELAPSED_INDIVIDUAL}"
    else
      ELAPSED_INDIVIDUAL=$(cat "${BASE_DIR}/impl/impl_${ID}.time" 2>/dev/null || echo "0")
      echo "FAILURE: impl_${ID} update failed in ${ELAPSED_INDIVIDUAL}s. Check log: ${LOGS["$ID"]}"
      FAILED_IMPLS+=("${ID}")
      INDIVIDUAL_TIMES["$ID"]="${ELAPSED_INDIVIDUAL}"
    fi
    rm -f "${BASE_DIR}/impl/impl_${ID}.time"
  done
fi

if [ ${#FAILED_IMPLS[@]} -gt 0 ]; then
  echo "Warning: The following implementations failed to update: ${FAILED_IMPLS[*]}"
  echo "Continuing to push check..."
fi

# 4. Check and Push Git Updates for Each Implementation
echo "=== Checking and Pushing Git Updates ==="
for ID in "${IMPLEMENTATIONS[@]}"; do
  IMPL_DIR="${BASE_DIR}/impl/${ID}"
  cd "${IMPL_DIR}"

  echo "Checking git status for impl_${ID}..."
  UNCOMMITTED=$(git status --porcelain 2>/dev/null || echo "")
  if [ -n "${UNCOMMITTED}" ]; then
    echo "WARNING: There are uncommitted/unstaged changes in impl_${ID}:"
    echo "${UNCOMMITTED}"
  fi

  # Find unpushed commits against upstream
  UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "origin/impl_${ID}")
  UNPUSHED_COMMITS=$(git log "${UPSTREAM}..HEAD" --oneline -n 3 2>/dev/null || echo "")
  TOTAL_UNPUSHED=$(git rev-list --count "${UPSTREAM}..HEAD" 2>/dev/null || echo "0")

  if [ "${TOTAL_UNPUSHED}" -gt 0 ]; then
    echo "Found ${TOTAL_UNPUSHED} unpushed commits in impl_${ID}:"
    echo "${UNPUSHED_COMMITS}"
    if [ "${TOTAL_UNPUSHED}" -gt 3 ]; then
      echo "... (truncated ${TOTAL_UNPUSHED} total)"
    fi
    echo "Pushing updates to origin/impl_${ID}..."
    git push origin "HEAD:impl_${ID}"
  else
    echo "No unpushed commits for impl_${ID}."
  fi
done

echo "=== All Update Tasks Completed ==="
echo ""
echo "=== Workflow Time Report ==="
for ID in "${IMPLEMENTATIONS[@]}"; do
  echo "Update impl_${ID}:  ${INDIVIDUAL_TIMES["$ID"]}s"
done
echo "============================="
