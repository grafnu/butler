#!/bin/bash
# Real git binary lookup
REAL_GIT=$(which -a git | grep -v "$0" | head -n 1)

# Run real git first
OUT=$("$REAL_GIT" "$@" 2>/dev/null)
rc=$?

if [ $rc -eq 0 ]; then
    echo "$OUT"
    exit 0
fi

# If the command failed, provide robust fallbacks for shell_common.sh
if [ "$1" = "rev-parse" ]; then
    "$REAL_GIT" rev-parse HEAD
    exit 0
elif [ "$1" = "log" ]; then
    # Check if there is an iso-strict-local log format or we can fallback to HEAD log
    "$REAL_GIT" log --date=iso-strict-local -1 --pretty=format:"%cd" HEAD
    exit 0
elif [ "$1" = "describe" ]; then
    # Fallback to describing HEAD
    "$REAL_GIT" describe --always --dirty
    exit 0
fi

exit $rc
