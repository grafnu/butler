#!/bin/bash
#
#
# This script constructs the base directory structure (cloning sibling repos/branches as needed),
# runs the parallel Gemini update workflow on implementations A, B, C, D, checks and pushes git updates,
# and finally runs the Gemini merger integration tests.
#
# Usage: ./bin/run_workflow.sh

set -euo pipefail

# Force non-interactive fail-fast execution across all sub-shells/tools
export CLOUDSDK_CORE_DISABLE_PROMPTS=1
export DEBIAN_FRONTEND=noninteractive
export SUDO_ASKPASS=/bin/false

# 1. Internal Configuration
IMPLEMENTATIONS=("A" "B" "C" "D")

if ! command -v gemini >/dev/null 2>&1; then
  echo "Error: gemini executable not found in PATH." >&2
  exit 1
fi
GEMINI_BIN="gemini"

GEMINI_OPTS=("--proxy=false" "--approval-mode" "yolo")

# Determine if sandbox mode should be used (default: false)
USE_SANDBOX="${USE_SANDBOX:-false}"
for arg in "$@"; do
  if [ "$arg" = "-s" ] || [ "$arg" = "--sandbox" ]; then
    USE_SANDBOX="true"
  fi
done

SANDBOX_OPTS=()
if [ "${USE_SANDBOX}" = "true" ]; then
  SANDBOX_OPTS=("-s")
fi

# Determine directories
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAIN_DIR="$(cd "${SCRIPT_DIR}" && pwd)"
BASE_DIR="${MAIN_DIR}"

echo "=== System Configuration ==="
echo "Script directory:       ${SCRIPT_DIR}"
echo "Main workspace:         ${MAIN_DIR}"
echo "Base workspace directory: ${BASE_DIR}"
echo "Sub-implementations:   ${IMPLEMENTATIONS[*]}"
echo "Sandbox mode enabled:   ${USE_SANDBOX}"
echo "============================="

# 2. Construct Base Directory Structure as Needed
cd "${MAIN_DIR}"

# Helper function to clone/setup a sibling directory with its branch
setup_sibling() {
  local dir_name="$1"
  local branch_name="$2"
  local target_dir="${BASE_DIR}/${dir_name}"

  # Ensure the branch exists and is fully up-to-date locally in MAIN_DIR
  # so that git clone . copies the freshest commit from origin
  cd "${MAIN_DIR}"
  local current_branch
  current_branch=$(git rev-parse --abbrev-ref HEAD)
  if [ "${branch_name}" != "${current_branch}" ]; then
    if git show-ref --verify --quiet "refs/remotes/origin/${branch_name}"; then
      echo "Updating/creating local branch ${branch_name} in MAIN_DIR to match origin/${branch_name}..."
      git branch -f "${branch_name}" "origin/${branch_name}"
    fi
  fi

  if [ ! -d "${target_dir}" ]; then
    echo "Directory ${dir_name} not found. Cloning into ${target_dir}..."
    mkdir -p "$(dirname "${target_dir}")"
    cd "${BASE_DIR}"
    git clone . "${dir_name}"
  fi

  cd "${target_dir}"
  echo "Fetching all updates for ${dir_name}..."
  git fetch --all --prune

  # Switch to the correct branch
  if git show-ref --verify --quiet "refs/heads/${branch_name}"; then
    echo "Switching ${dir_name} to existing local branch ${branch_name}..."
    git checkout "${branch_name}"
  else
    echo "Checking out new tracking branch ${branch_name} from origin/${branch_name} in ${dir_name}..."
    git checkout -b "${branch_name}" "origin/${branch_name}"
  fi
  
  # Ensure the working directory is updated to match origin
  echo "Resetting ${dir_name} to origin/${branch_name} to ensure freshness..."
  git reset --hard "origin/${branch_name}"
}

# Setup implementations
for ID in "${IMPLEMENTATIONS[@]}"; do
  setup_sibling "impl/${ID}" "impl_${ID}"
done

# Setup merger
setup_sibling "merger" "merger"

echo "=== Base Directory Structure Verified/Constructed ==="

# 3. Run Parallel Gemini Update Workflows (@UPDATE.md)
echo "=== Running Parallel Gemini Updates (@UPDATE.md) ==="
declare -A PIDS
declare -A LOGS

for ID in "${IMPLEMENTATIONS[@]}"; do
  IMPL_DIR="${BASE_DIR}/impl/${ID}"
  LOG_FILE="${IMPL_DIR}.log"
  LOGS["$ID"]="${LOG_FILE}"
  
  echo "Launching gemini ${SANDBOX_OPTS[*]} -p @UPDATE.md for impl_${ID} in background (logging to ${LOG_FILE})..."
  (
    START_INDIVIDUAL=$SECONDS
    cd "${IMPL_DIR}"
    # Execute Gemini using the specified options and input @UPDATE.md
    "${GEMINI_BIN}" "${GEMINI_OPTS[@]}" "${SANDBOX_OPTS[@]}" -p @UPDATE.md < /dev/null > "${LOG_FILE}" 2>&1
    RET=$?
    ELAPSED_INDIVIDUAL=$(( SECONDS - START_INDIVIDUAL ))
    echo "${ELAPSED_INDIVIDUAL}" > "${BASE_DIR}/impl/impl_${ID}.time"
    exit ${RET}
  ) &
  PIDS["$ID"]=$!
done

# Wait for all processes to complete
echo "Waiting for parallel update processes to complete..."
FAILED_IMPLS=()
declare -A INDIVIDUAL_TIMES
for ID in "${IMPLEMENTATIONS[@]}"; do
  PID=${PIDS["$ID"]}
  if wait "${PID}"; then
    ELAPSED_INDIVIDUAL=$(cat "${BASE_DIR}/impl/impl_${ID}.time" 2>/dev/null || echo "0")
    echo "SUCCESS: impl_${ID} updated successfully in ${ELAPSED_INDIVIDUAL}s."
    INDIVIDUAL_TIMES["$ID"]="${ELAPSED_INDIVIDUAL}"
  else
    ELAPSED_INDIVIDUAL=$(cat "${BASE_DIR}/impl/impl_${ID}.time" 2>/dev/null || echo "0")
    echo "FAILURE: impl_${ID} update failed in ${ELAPSED_INDIVIDUAL}s. Check log: ${LOGS["$ID"]}"
    FAILED_IMPLS+=("${ID}")
    INDIVIDUAL_TIMES["$ID"]="${ELAPSED_INDIVIDUAL}"
  fi
  rm -f "${BASE_DIR}/impl/impl_${ID}.time"
done

if [ ${#FAILED_IMPLS[@]} -gt 0 ]; then
  echo "Warning: The following implementations failed to update: ${FAILED_IMPLS[*]}"
  echo "Continuing to push check and merger as requested..."
fi

# 4. Check and Push Git Updates for Each Implementation
echo "=== Checking and Pushing Git Updates ==="
for ID in "${IMPLEMENTATIONS[@]}"; do
  IMPL_DIR="${BASE_DIR}/impl/${ID}"
  cd "${IMPL_DIR}"
  
  echo "Checking git status for impl_${ID}..."
  UNCOMMITTED=$(git status --porcelain 2>/dev/null || echo "")
  if [ -n "${UNCOMMITTED}" ]; then
    echo "WARNING: There are uncommitted/unstaged changes in impl_${ID}:"
    echo "${UNCOMMITTED}"
  fi
  
  # Find unpushed commits against upstream
  UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "origin/impl_${ID}")
  UNPUSHED_COMMITS=$(git log "${UPSTREAM}..HEAD" --oneline -n 3 2>/dev/null || echo "")
  TOTAL_UNPUSHED=$(git rev-list --count "${UPSTREAM}..HEAD" 2>/dev/null || echo "0")
  
  if [ "${TOTAL_UNPUSHED}" -gt 0 ]; then
    echo "Found ${TOTAL_UNPUSHED} unpushed commits in impl_${ID}:"
    echo "${UNPUSHED_COMMITS}"
    if [ "${TOTAL_UNPUSHED}" -gt 3 ]; then
      echo "... (truncated ${TOTAL_UNPUSHED} total)"
    fi
    echo "Pushing updates to origin/impl_${ID}..."
    git push origin "HEAD:impl_${ID}"
  else
    echo "No unpushed commits for impl_${ID}."
  fi
done

# 5. Run the Gemini Merger Workflow (@MERGER.md)
echo "=== Running Gemini Merger (@MERGER.md) ==="
START_MERGER=$SECONDS
cd "${BASE_DIR}/merger"
echo "Executing gemini ${SANDBOX_OPTS[*]} -p @MERGER.md in merger..."
LOG_FILE_MERGER="${BASE_DIR}/merger.log"
echo "Logging output to ${LOG_FILE_MERGER}..."

if "${GEMINI_BIN}" "${GEMINI_OPTS[@]}" "${SANDBOX_OPTS[@]}" -p @MERGER.md < /dev/null > "${LOG_FILE_MERGER}" 2>&1; then
  echo "SUCCESS: Gemini merger run completed successfully."
else
  echo "FAILURE: Gemini merger run failed. Check log: ${LOG_FILE_MERGER}"
  exit 1
fi

ELAPSED_MERGER=$(( SECONDS - START_MERGER ))
echo "=== Gemini Merger completed in ${ELAPSED_MERGER}s ==="

# Check and push any merger changes
UPSTREAM_MERGER=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "origin/merger")
UNPUSHED_MERGER=$(git log "${UPSTREAM_MERGER}..HEAD" --oneline 2>/dev/null || echo "")
TOTAL_UNPUSHED_MERGER=$(git rev-list --count "${UPSTREAM_MERGER}..HEAD" 2>/dev/null || echo "0")

if [ "${TOTAL_UNPUSHED_MERGER}" -gt 0 ]; then
  echo "Found ${TOTAL_UNPUSHED_MERGER} unpushed commits in merger:"
  echo "${UNPUSHED_MERGER}"
  echo "Pushing merger updates to origin/merger..."
  git push origin HEAD:merger
else
  echo "No unpushed commits for merger."
fi

echo "=== All Workflow Tasks Completed ==="
echo ""
echo "=== Workflow Time Report ==="
for ID in "${IMPLEMENTATIONS[@]}"; do
  echo "Update impl_${ID}:  ${INDIVIDUAL_TIMES["$ID"]}s"
done
echo "Gemini Merger:    ${ELAPSED_MERGER}s"
echo "============================="
